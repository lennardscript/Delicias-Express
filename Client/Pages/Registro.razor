@page "/registro"

<PageTitle>Registro</PageTitle>

<h1>Registro</h1>


<form method="post" style="max-width: 700px; margin: 0 auto;">
    <div style="display: flex; justify-content: space-between; margin-bottom: 30px;">
        <div style="flex-basis: 43%;">
            <label for="empresa">Nombre de la empresa:</label>
            <input class="input-style" type="text" id="empresa" name="empresa" style="width: 100%; padding: 8px; box-sizing: border-box;" required />
        </div>
        <div style="flex-basis: 43%;">
            <label for="rut">RUT de la empresa:</label>
            <input class="input-style" placeholder="sin puntos y con dígito verificador" type="text" id="rut" name="rut" style="width: 100%; padding: 8px; box-sizing: border-box;" required />
        </div>
    </div>
    <div style="display: flex; justify-content: space-between; margin-bottom: 30px;">
        <div style="flex-basis: 43%;">
            <label for="razon_social">Razón Social:</label>
            <input class="input-style" type="text" id="razon_social" name="razon_social" style="width: 100%; padding: 8px; box-sizing: border-box;" required />
        </div>
        <div style="flex-basis: 43%;">
            <label for="tipo_servicio">Tipo de Servicio:</label>
            <select class="input-style" id="tipo_servicio" name="tipo_servicio" style="width: 100%; padding: 8px; box-sizing: border-box;" required>
                <option value="">Seleccione...</option>
                <option value="Servicio 1">Servicio 1</option>
                <option value="Servicio 2">Servicio 2</option>
                <option value="Servicio 3">Servicio 3</option>
            </select>
        </div>
        
    </div>
    <div style="display: flex; justify-content: space-between; margin-bottom: 30px;">
        <div style="flex-basis: 43%;">
            <label for="correo">Correo:</label>
            <input class="input-style" placeholder="proveedor@ventas.com" type="email" id="correo" name="correo" style="width: 100%; padding: 8px; box-sizing: border-box;" required />
        </div>
        <div style="flex-basis: 43%;">
            <label for="direccion">Dirección:</label>
            <input class="input-style" placeholder="Calle 123, CABA, Chile" type="text" id="direccion" name="direccion" style="width: 100%; padding: 8px; box-sizing: border-box;" required />
        </div>
    </div>
    <div style="display: flex; justify-content: space-between; margin-bottom: 30px;">
        <div style="flex-basis: 43%;">
            <label for="telefono">Número de teléfono:</label>
            <input class="input-style" placeholder="973625163" type="tel" id="telefono" name="telefono" style="width: 100%; padding: 8px; box-sizing: border-box;" required />
        </div>
        <div style="flex-basis: 43%;">
            <label for="sitio_web">Sitio Web:</label>
            <input class="input-style" placeholder="www.miweb.com" type="url" id="sitio_web" name="sitio_web" style="width: 100%; padding: 8px; box-sizing: border-box;" required />
        </div>
    </div>
    <div style="display: flex; justify-content: space-between; margin-bottom: 30px;">
        <div style="flex-basis: 43%;">
            <label for="password">Contraseña:</label>
            <input class="input-style" type="password" id="password" name="password" style="width: 100%; padding: 8px; box-sizing: border-box;" required />
        </div>
        <div style="flex-basis: 43%;">
            <label for="confirm_password">Confirmar Contraseña:</label>
            <input class="input-style" type="password" id="confirm_password" name="confirm_password" style="width: 100%; padding: 8px; box-sizing: border-box;" required />
        </div>
    </div>
   
    <div style="margin-top: 30px;">
        <button type="submit" style="color: #fff; background-color: darkorange; padding: 1.3em 3em; font-size: 12px; text-transform: uppercase; letter-spacing: 2.5px; font-weight: 500;  border: none; border-radius: 45px; transition: all 0.3s ease 0s; cursor: pointer; outline: none;">Registrarse</button>
    </div>
    
</form>

<style>
    .input-style {
        padding: 10px;
        border: 2px solid #ccc;
        border-radius: 5px;
        font-size: 16px;
        outline: none;
    }

        .input-style:focus {
            border-color: #007bff;
            box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
        }

    button:hover {
        
        box-shadow: 0px 15px 20px rgba(46, 229, 157, 0.4);
        
        transform: translateY(-7px);
    }

    button:active {
        transform: translateY(-1px);
    }
</style>