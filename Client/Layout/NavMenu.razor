<div class="top-row ps-3 navbar navbar-light">
    <div class="container-fluid">
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/home" Match="NavLinkMatch.All">
                <span class="p-2" aria-hidden="true">
                    <Icon class="mx-1" Name="IconName.HouseDoor" Size="IconSize.x5"/> Inicio
                </span>
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/facturacion">
                <span class="p-2" aria-hidden="true">
                    <Icon class="mx-1" Name="IconName.CashCoin" Size="IconSize.x5"/> Facturación
                </span>
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/ordenes">
                <span class="p-2" aria-hidden="true">
                    <Icon class="mx-1" Name="IconName.ClipboardCheck" Size="IconSize.x5"/> Ordenes
                </span>
            </NavLink>
        </div>

        <div class="nav-item px-3 fixed-bottom mt-auto mb-3">
            <span class="p-2 text-white" aria-hidden="true">
                <Icon class="mx-1" Name="IconName.Person" Size="IconSize.x5"/> usuario@mail.com
            </span>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

}